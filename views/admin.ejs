<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة تحكم AJMAN LUXURY</title>
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <aside class="admin-sidebar">
        <img src="/images/logo-wordmark.png" alt="AJMAN LUXURY">
        <nav>
            <button type="button" class="tab-button active" data-tab="dashboard">الرئيسية</button>
            <button type="button" class="tab-button" data-tab="orders">الطلبات</button>
            <button type="button" class="tab-button" data-tab="chat">رسائل الواتساب</button>
            <button type="button" class="tab-button" data-tab="content">محتوى الموقع</button>
            <button type="button" class="tab-button" data-tab="products">العطور</button>
            <button type="button" class="tab-button" data-tab="journal">المجلة</button>
            <button type="button" class="tab-button" data-tab="testimonials">آراء العملاء</button>
            <button type="button" class="tab-button" data-tab="design">التصميم</button>
        </nav>
        <a class="site-link" href="/?lang=ar" target="_blank">عرض الموقع</a>
        <form action="<%= adminBase || '/admin' %>/logout" method="POST">
            <button type="submit" class="logout-button">تسجيل الخروج</button>
        </form>
    </aside>

    <main class="admin-main">
        <header class="admin-header">
            <div>
                <p>لوحة إدارة المحتوى والتصميم</p>
                <h1>تحكم سريع بموقع العطور</h1>
            </div>
            <% if (saved) { %>
                <div class="save-alert">تم حفظ التغييرات بنجاح</div>
            <% } %>
        </header>

        <form action="<%= adminBase || '/admin' %>/save" method="POST" class="admin-form" id="adminForm">
            <section class="tab-panel active" data-panel="dashboard">
                <div class="stats-grid">
                    <article>
                        <strong><%= siteData.products.length %></strong>
                        <span>عطور</span>
                    </article>
                    <article>
                        <strong><%= siteData.posts.length %></strong>
                        <span>مقالات</span>
                    </article>
                    <article>
                        <strong><%= siteData.testimonials.length %></strong>
                        <span>آراء عملاء</span>
                    </article>
                    <article>
                        <strong><%= orders.length %></strong>
                        <span>طلبات</span>
                    </article>
                    <article>
                        <strong><%= chatMessages.length %></strong>
                        <span>رسائل واتساب</span>
                    </article>
                </div>

                <div class="admin-card">
                    <h2>ابدأ من هنا</h2>
                    <p>عدّل النصوص الرئيسية، أسعار العطور، المقالات، ألوان الهوية، ثم اضغط حفظ التغييرات. أي تعديل يظهر مباشرة على الموقع.</p>
                    <div class="quick-actions">
                        <button type="button" class="tab-shortcut" data-tab="content">تعديل النصوص</button>
                        <button type="button" class="tab-shortcut" data-tab="products">إدارة العطور</button>
                        <button type="button" class="tab-shortcut" data-tab="design">تخصيص التصميم</button>
                    </div>
                </div>
            </section>

            <section class="tab-panel" data-panel="orders">
                <div class="panel-toolbar">
                    <h2>إدارة الطلبات</h2>
                    <span class="orders-note">الطلبات تحفظ تلقائياً عند إتمام الدفع أو طلب المتابعة اليدوية.</span>
                </div>
                <% if (orders.length) { %>
                    <div class="orders-table">
                        <% orders.forEach((order) => { %>
                            <article class="order-card">
                                <div class="order-head">
                                    <div>
                                        <strong><%= order.id %></strong>
                                        <span><%= new Date(order.createdAt).toLocaleString('en-GB') %></span>
                                    </div>
                                    <span class="status-badge"><%= order.status %></span>
                                </div>
                                <div class="order-customer">
                                    <span><%= order.customer.name || '-' %></span>
                                    <span><%= order.customer.phone || '-' %></span>
                                    <span><%= order.customer.email || '-' %></span>
                                </div>
                                <div class="order-items">
                                    <% order.items.forEach((item) => { %>
                                        <span><%= item.name %> × <%= item.quantity %></span>
                                    <% }) %>
                                </div>
                                <div class="order-total">
                                    <span><%= order.paymentProvider %></span>
                                    <strong><%= order.currency %> <%= (order.total / 100).toFixed(2) %></strong>
                                </div>
                            </article>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="admin-card">
                        <h2>لا توجد طلبات بعد</h2>
                        <p>عندما يضيف العميل عطراً للسلة ويتمم الطلب، سيظهر هنا.</p>
                    </div>
                <% } %>
            </section>

            <section class="tab-panel" data-panel="chat">
                <div class="panel-toolbar">
                    <h2>رسائل دردشة الواتساب</h2>
                    <span class="orders-note">هذه الرسائل أرسلها العملاء من النافذة الصغيرة داخل الموقع دون مغادرة الصفحة.</span>
                </div>
                <% if (chatMessages.length) { %>
                    <div class="orders-table">
                        <% chatMessages.forEach((chat) => { %>
                            <article class="order-card chat-admin-card">
                                <div class="order-head">
                                    <div>
                                        <strong><%= chat.customer.name || 'زائر الموقع' %></strong>
                                        <span><%= new Date(chat.createdAt).toLocaleString('en-GB') %></span>
                                    </div>
                                    <span class="status-badge"><%= chat.status %></span>
                                </div>
                                <p class="chat-admin-message"><%= chat.message %></p>
                                <div class="order-customer">
                                    <span>الهاتف: <%= chat.customer.phone || '-' %></span>
                                    <span>اللغة: <%= chat.lang %></span>
                                </div>
                                <div class="order-total">
                                    <span><%= chat.id %></span>
                                    <% if (chat.customer.phone) { %>
                                        <a class="secondary-button" target="_blank" rel="noopener" href="https://wa.me/<%= String(chat.customer.phone).replace(/\\D/g, '') %>">رد عبر واتساب</a>
                                    <% } %>
                                </div>
                            </article>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="admin-card">
                        <h2>لا توجد رسائل بعد</h2>
                        <p>عندما يرسل العميل استفساراً من نافذة الدردشة داخل الموقع، سيظهر هنا.</p>
                    </div>
                <% } %>
            </section>

            <section class="tab-panel" data-panel="content">
                <div class="admin-card">
                    <h2>نصوص الصفحة الرئيسية</h2>
                    <div class="field-grid">
                        <label>عنوان عربي<input name="translations[ar][welcome]" value="<%= siteData.translations.ar.welcome %>"></label>
                        <label>عنوان إنجليزي<input name="translations[en][welcome]" value="<%= siteData.translations.en.welcome %>"></label>
                        <label>وصف عربي<textarea name="translations[ar][subtitle]"><%= siteData.translations.ar.subtitle %></textarea></label>
                        <label>وصف إنجليزي<textarea name="translations[en][subtitle]"><%= siteData.translations.en.subtitle %></textarea></label>
                        <label>تعريف قصير عربي<input name="translations[ar][heroEyebrow]" value="<%= siteData.translations.ar.heroEyebrow %>"></label>
                        <label>تعريف قصير إنجليزي<input name="translations[en][heroEyebrow]" value="<%= siteData.translations.en.heroEyebrow %>"></label>
                    </div>
                </div>

                <div class="admin-card">
                    <h2>من نحن والتواصل</h2>
                    <div class="field-grid">
                        <label>عنوان من نحن عربي<input name="translations[ar][aboutTitle]" value="<%= siteData.translations.ar.aboutTitle %>"></label>
                        <label>About title<input name="translations[en][aboutTitle]" value="<%= siteData.translations.en.aboutTitle %>"></label>
                        <label>نص من نحن عربي<textarea name="translations[ar][aboutText1]"><%= siteData.translations.ar.aboutText1 %></textarea></label>
                        <label>About text<textarea name="translations[en][aboutText1]"><%= siteData.translations.en.aboutText1 %></textarea></label>
                        <label>الهاتف<input name="translations[ar][phone_label]" value="<%= siteData.translations.ar.phone_label %>"></label>
                        <label>Phone<input name="translations[en][phone_label]" value="<%= siteData.translations.en.phone_label %>"></label>
                        <label>البريد<input name="translations[ar][email_label]" value="<%= siteData.translations.ar.email_label %>"></label>
                        <label>Email<input name="translations[en][email_label]" value="<%= siteData.translations.en.email_label %>"></label>
                        <label>العنوان عربي<input name="translations[ar][address_label]" value="<%= siteData.translations.ar.address_label %>"></label>
                        <label>Address<input name="translations[en][address_label]" value="<%= siteData.translations.en.address_label %>"></label>
                    </div>
                </div>
            </section>

            <section class="tab-panel" data-panel="products">
                <div class="panel-toolbar">
                    <h2>إدارة العطور</h2>
                    <button type="button" class="secondary-button" data-add="product-list">إضافة عطر</button>
                </div>
                <div id="product-list" class="repeat-list">
                    <% siteData.products.forEach((product, index) => { %>
                        <article class="admin-card repeat-item">
                            <div class="item-heading">
                                <h3>عطر <%= index + 1 %></h3>
                                <button type="button" class="danger-button" data-remove>حذف</button>
                            </div>
                            <div class="field-grid">
                                <label>Slug<input name="products[<%= index %>][id]" value="<%= product.id %>"></label>
                                <label>رابط الصورة<input name="products[<%= index %>][image]" value="<%= product.image || '' %>" placeholder="/images/products/example.jpeg"></label>
                                <label>لون البطاقة
                                    <select name="products[<%= index %>][tone]">
                                        <option value="noir" <%= product.tone === 'noir' ? 'selected' : '' %>>أسود فاخر</option>
                                        <option value="rose" <%= product.tone === 'rose' ? 'selected' : '' %>>وردي</option>
                                        <option value="royal" <%= product.tone === 'royal' ? 'selected' : '' %>>أزرق ملكي</option>
                                        <option value="pearl" <%= product.tone === 'pearl' ? 'selected' : '' %>>أبيض لؤلؤي</option>
                                        <option value="sapphire" <%= product.tone === 'sapphire' ? 'selected' : '' %>>أزرق فاخر</option>
                                    </select>
                                </label>
                                <label>اسم عربي<input name="products[<%= index %>][name][ar]" value="<%= product.name.ar %>"></label>
                                <label>Name<input name="products[<%= index %>][name][en]" value="<%= product.name.en %>"></label>
                                <label>السعر عربي<input name="products[<%= index %>][price][ar]" value="<%= product.price.ar %>"></label>
                                <label>Price<input name="products[<%= index %>][price][en]" value="<%= product.price.en %>"></label>
                                <label>الحجم عربي<input name="products[<%= index %>][size][ar]" value="<%= product.size.ar %>"></label>
                                <label>Size<input name="products[<%= index %>][size][en]" value="<%= product.size.en %>"></label>
                                <label>الوصف عربي<textarea name="products[<%= index %>][description][ar]"><%= product.description.ar %></textarea></label>
                                <label>Description<textarea name="products[<%= index %>][description][en]"><%= product.description.en %></textarea></label>
                                <label>المقدمة<input name="products[<%= index %>][topNotes][ar]" value="<%= product.topNotes.ar %>"></label>
                                <label>Top notes<input name="products[<%= index %>][topNotes][en]" value="<%= product.topNotes.en %>"></label>
                                <label>القلب<input name="products[<%= index %>][heartNotes][ar]" value="<%= product.heartNotes.ar %>"></label>
                                <label>Heart notes<input name="products[<%= index %>][heartNotes][en]" value="<%= product.heartNotes.en %>"></label>
                                <label>القاعدة<input name="products[<%= index %>][baseNotes][ar]" value="<%= product.baseNotes.ar %>"></label>
                                <label>Base notes<input name="products[<%= index %>][baseNotes][en]" value="<%= product.baseNotes.en %>"></label>
                            </div>
                        </article>
                    <% }) %>
                </div>
            </section>

            <section class="tab-panel" data-panel="journal">
                <div class="panel-toolbar">
                    <h2>المجلة</h2>
                    <button type="button" class="secondary-button" data-add="post-list">إضافة مقال</button>
                </div>
                <div id="post-list" class="repeat-list">
                    <% siteData.posts.forEach((post, index) => { %>
                        <article class="admin-card repeat-item">
                            <div class="item-heading">
                                <h3>مقال <%= index + 1 %></h3>
                                <button type="button" class="danger-button" data-remove>حذف</button>
                            </div>
                            <div class="field-grid">
                                <label>Slug<input name="posts[<%= index %>][id]" value="<%= post.id %>"></label>
                                <label>التاريخ عربي<input name="posts[<%= index %>][date][ar]" value="<%= post.date.ar %>"></label>
                                <label>Date<input name="posts[<%= index %>][date][en]" value="<%= post.date.en %>"></label>
                                <label>عنوان عربي<input name="posts[<%= index %>][title][ar]" value="<%= post.title.ar %>"></label>
                                <label>Title<input name="posts[<%= index %>][title][en]" value="<%= post.title.en %>"></label>
                                <label>ملخص عربي<textarea name="posts[<%= index %>][excerpt][ar]"><%= post.excerpt.ar %></textarea></label>
                                <label>Excerpt<textarea name="posts[<%= index %>][excerpt][en]"><%= post.excerpt.en %></textarea></label>
                                <label>المحتوى عربي<textarea name="posts[<%= index %>][content][ar]"><%= post.content.ar %></textarea></label>
                                <label>Content<textarea name="posts[<%= index %>][content][en]"><%= post.content.en %></textarea></label>
                            </div>
                        </article>
                    <% }) %>
                </div>
            </section>

            <section class="tab-panel" data-panel="testimonials">
                <div class="panel-toolbar">
                    <h2>آراء العملاء</h2>
                    <button type="button" class="secondary-button" data-add="testimonial-list">إضافة رأي</button>
                </div>
                <div id="testimonial-list" class="repeat-list">
                    <% siteData.testimonials.forEach((testimonial, index) => { %>
                        <article class="admin-card repeat-item">
                            <div class="item-heading">
                                <h3>رأي <%= index + 1 %></h3>
                                <button type="button" class="danger-button" data-remove>حذف</button>
                            </div>
                            <div class="field-grid">
                                <label>التقييم<input type="number" min="1" max="5" name="testimonials[<%= index %>][rating]" value="<%= testimonial.rating %>"></label>
                                <label>الاسم عربي<input name="testimonials[<%= index %>][name][ar]" value="<%= testimonial.name.ar %>"></label>
                                <label>Name<input name="testimonials[<%= index %>][name][en]" value="<%= testimonial.name.en %>"></label>
                                <label>المدينة عربي<input name="testimonials[<%= index %>][title][ar]" value="<%= testimonial.title.ar %>"></label>
                                <label>City<input name="testimonials[<%= index %>][title][en]" value="<%= testimonial.title.en %>"></label>
                                <label>الرأي عربي<textarea name="testimonials[<%= index %>][text][ar]"><%= testimonial.text.ar %></textarea></label>
                                <label>Review<textarea name="testimonials[<%= index %>][text][en]"><%= testimonial.text.en %></textarea></label>
                            </div>
                        </article>
                    <% }) %>
                </div>
            </section>

            <section class="tab-panel" data-panel="design">
                <div class="admin-card">
                    <h2>تخصيص التصميم</h2>
                    <div class="design-grid">
                        <label class="wide">الثيم
                            <select name="designSettings[themeMode]">
                                <option value="classic" <%= (siteData.designSettings.themeMode || 'classic') === 'classic' ? 'selected' : '' %>>الثيم الحالي الفاخر</option>
                                <option value="royal-purple" <%= siteData.designSettings.themeMode === 'royal-purple' ? 'selected' : '' %>>ثيم أسود وبنفسجي ملكي</option>
                            </select>
                        </label>
                        <label>لون النص الرئيسي<input type="color" name="designSettings[ink]" value="<%= siteData.designSettings.ink %>"></label>
                        <label>اللون الذهبي<input type="color" name="designSettings[gold]" value="<%= siteData.designSettings.gold %>"></label>
                        <label>الخلفية<input type="color" name="designSettings[paper]" value="<%= siteData.designSettings.paper %>"></label>
                        <label>خلفية الأقسام<input type="color" name="designSettings[mist]" value="<%= siteData.designSettings.mist %>"></label>
                        <label>شفافية شعار الواجهة<input type="range" min="0.05" max="0.4" step="0.01" name="designSettings[heroOpacity]" value="<%= siteData.designSettings.heroOpacity %>"></label>
                        <label>استدارة البطاقات<input name="designSettings[cardRadius]" value="<%= siteData.designSettings.cardRadius %>"></label>
                        <label class="wide">الخط<input name="designSettings[fontFamily]" value="<%= siteData.designSettings.fontFamily %>"></label>
                        <label class="wide">رقم واتساب خدمة العملاء<input name="designSettings[whatsappNumber]" value="<%= siteData.designSettings.whatsappNumber || '' %>" placeholder="971500000000"></label>
                    </div>
                </div>
                <div class="admin-card">
                    <h2>فيديو الهيرو</h2>
                    <p>ارفع فيديو بصيغة MP4 أو WEBM أو OGG. يفضل أن يكون قصيراً ومضغوطاً حتى يبقى الموقع سريعاً.</p>
                    <% if (siteData.designSettings.heroVideo) { %>
                        <video class="admin-video-preview" controls muted>
                            <source src="<%= siteData.designSettings.heroVideo %>">
                        </video>
                        <label>مسار الفيديو الحالي<input name="designSettings[heroVideo]" value="<%= siteData.designSettings.heroVideo %>"></label>
                    <% } else { %>
                        <label>مسار الفيديو الحالي<input name="designSettings[heroVideo]" value="" placeholder="/videos/hero.mp4"></label>
                    <% } %>
                    <div class="upload-form">
                        <label>رفع فيديو جديد<input form="heroVideoUploadForm" type="file" name="heroVideo" accept="video/mp4,video/webm,video/ogg" required></label>
                        <button form="heroVideoUploadForm" type="submit" class="secondary-button">رفع الفيديو</button>
                    </div>
                </div>
                <div class="admin-card">
                    <h2>أيقونة الموقع Favicon</h2>
                    <p>ارفع أيقونة بصيغة PNG أو SVG أو ICO. الأفضل مقاس مربع مثل 512×512 أو 180×180.</p>
                    <% if (siteData.designSettings.faviconPath) { %>
                        <img class="admin-favicon-preview" src="<%= siteData.designSettings.faviconPath %>" alt="Favicon preview">
                        <label>مسار الأيقونة الحالي<input name="designSettings[faviconPath]" value="<%= siteData.designSettings.faviconPath %>"></label>
                    <% } else { %>
                        <label>مسار الأيقونة الحالي<input name="designSettings[faviconPath]" value="/favicon.png"></label>
                    <% } %>
                    <div class="upload-form">
                        <label>رفع أيقونة جديدة<input form="faviconUploadForm" type="file" name="favicon" accept="image/png,image/svg+xml,image/x-icon,.ico" required></label>
                        <button form="faviconUploadForm" type="submit" class="secondary-button">رفع الأيقونة</button>
                    </div>
                </div>
            </section>

            <div class="save-bar">
                <button type="submit" class="save-button">حفظ التغييرات</button>
            </div>
        </form>
        <form id="heroVideoUploadForm" action="<%= adminBase || '/admin' %>/upload-hero-video" method="POST" enctype="multipart/form-data"></form>
        <form id="faviconUploadForm" action="<%= adminBase || '/admin' %>/upload-favicon" method="POST" enctype="multipart/form-data"></form>
    </main>

    <script>
        const tabButtons = document.querySelectorAll('.tab-button, .tab-shortcut');
        const panels = document.querySelectorAll('.tab-panel');

        tabButtons.forEach((button) => {
            button.addEventListener('click', () => {
                const tab = button.dataset.tab;
                document.querySelectorAll('.tab-button').forEach((item) => item.classList.toggle('active', item.dataset.tab === tab));
                panels.forEach((panel) => panel.classList.toggle('active', panel.dataset.panel === tab));
            });
        });

        document.querySelectorAll('[data-remove]').forEach((button) => {
            button.addEventListener('click', () => {
                const list = button.closest('.repeat-list');
                if (list.children.length > 1) {
                    button.closest('.repeat-item').remove();
                    renumberList(list);
                }
            });
        });

        document.querySelectorAll('[data-add]').forEach((button) => {
            button.addEventListener('click', () => {
                const list = document.getElementById(button.dataset.add);
                const clone = list.querySelector('.repeat-item').cloneNode(true);
                clone.querySelectorAll('input, textarea').forEach((field) => {
                    if (field.type !== 'number') {
                        field.value = '';
                    }
                });
                clone.querySelectorAll('[data-remove]').forEach((removeButton) => {
                    removeButton.addEventListener('click', () => {
                        if (list.children.length > 1) {
                            removeButton.closest('.repeat-item').remove();
                            renumberList(list);
                        }
                    });
                });
                list.appendChild(clone);
                renumberList(list);
            });
        });

        function renumberList(list) {
            const prefix = list.id === 'product-list' ? 'products' : list.id === 'post-list' ? 'posts' : 'testimonials';
            list.querySelectorAll('.repeat-item').forEach((item, index) => {
                const title = item.querySelector('h3');
                if (title) {
                    title.textContent = title.textContent.replace(/\d+/, index + 1);
                }
                item.querySelectorAll('[name]').forEach((field) => {
                    field.name = field.name.replace(new RegExp(`${prefix}\\[\\d+\\]`), `${prefix}[${index}]`);
                });
            });
        }
    </script>
</body>
</html>
