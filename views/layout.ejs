<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= isRTL ? 'rtl' : 'ltr' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="<%= t.siteName %> - <%= t.footerTagline %>">
    <meta name="keywords" content="AJMAN LUXURY, luxury perfumes, oud, extrait de parfum, UAE perfume">
    <title><%= t.siteName %></title>
    <link rel="icon" href="<%= designSettings.faviconPath || '/favicon.png' %>">
    <link rel="shortcut icon" href="<%= designSettings.faviconPath || '/favicon.png' %>">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        :root {
            --ink: <%- designSettings.ink %>;
            --gold: <%- designSettings.gold %>;
            --paper: <%- designSettings.paper %>;
            --mist: <%- designSettings.mist %>;
            --card-radius: <%- designSettings.cardRadius %>;
            --hero-logo-opacity: <%- designSettings.heroOpacity %>;
            --site-font: <%- designSettings.fontFamily %>;
        }
    </style>
</head>
<body class="theme-<%= designSettings.themeMode || 'classic' %>">
    <div class="top-offer-bar">
        <span><%= lang === 'ar' ? 'عروض حصرية على عطور عجمان لكجري' : 'Exclusive offers on AJMAN LUXURY perfumes' %></span>
    </div>

    <header class="site-header">
        <nav class="site-nav" aria-label="Primary navigation">
            <a class="brand" href="/?lang=<%= lang %>" aria-label="<%= t.siteName %>">
                <img src="/images/logo-wordmark.png" alt="<%= t.siteName %>" class="brand-wordmark">
            </a>

            <ul class="nav-links">
                <li><a href="/?lang=<%= lang %>"><%= t.home %></a></li>
                <li><a href="/products?lang=<%= lang %>"><%= t.products %></a></li>
                <li><a href="/scent-finder?lang=<%= lang %>"><%= t.scentFinder %></a></li>
                <li><a href="/about?lang=<%= lang %>"><%= t.about %></a></li>
                <li><a href="/contact?lang=<%= lang %>"><%= t.contact %></a></li>
            </ul>

            <div class="header-tools">
                <div class="lang-switch" aria-label="Language switcher">
                    <a href="<%= currentPath %>?lang=en" class="<%= lang === 'en' ? 'active' : '' %>">EN</a>
                    <a href="<%= currentPath %>?lang=ar" class="<%= lang === 'ar' ? 'active' : '' %>">عربي</a>
                </div>
                <div class="store-actions" aria-label="Store actions">
                    <a href="/admin/login" title="<%= lang === 'ar' ? 'لوحة التحكم' : 'Admin' %>">◎</a>
                    <a href="/contact?lang=<%= lang %>" title="<%= lang === 'ar' ? 'الدعم' : 'Support' %>">♡</a>
                    <a href="/checkout?lang=<%= lang %>" class="bag-link" title="<%= lang === 'ar' ? 'سلة المشتريات' : 'Shopping cart' %>" aria-label="<%= lang === 'ar' ? 'سلة المشتريات' : 'Shopping cart' %>">
                        <svg class="cart-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M7 18.5a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3Zm10 0a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3ZM4.2 4l2.1 10.2A2.2 2.2 0 0 0 8.5 16h7.8a2.2 2.2 0 0 0 2.1-1.6l1.5-5.6A1.4 1.4 0 0 0 18.6 7H7.1L6.6 4.6A2 2 0 0 0 4.7 3H3a1 1 0 1 0 0 2h1.2Zm3.3 5h10.1l-1.2 4.8a.3.3 0 0 1-.3.2H8.5a.3.3 0 0 1-.3-.2L7.5 9Z"/>
                        </svg>
                        <span class="cart-label"><%= lang === 'ar' ? 'السلة' : 'Cart' %></span>
                        <span class="cart-count" data-cart-count>0</span>
                    </a>
                </div>
            </div>
        </nav>
    </header>

    <main>
        <%- body %>
    </main>

    <footer class="site-footer">
        <div class="container footer-inner">
            <img src="/images/logo-wordmark.png" alt="<%= t.siteName %>" class="footer-logo">
            <p>&copy; 2026 <%= t.siteName %>. <%= t.footerTagline %>.</p>
            <div class="footer-links">
                <a href="/gallery?lang=<%= lang %>"><%= t.gallery %></a>
                <a href="/blog?lang=<%= lang %>"><%= t.blog %></a>
                <a href="/testimonials?lang=<%= lang %>"><%= t.testimonials %></a>
            </div>
        </div>
    </footer>

    <div class="whatsapp-widget" data-whatsapp-widget data-lang="<%= lang %>">
        <section class="whatsapp-panel" data-whatsapp-panel hidden aria-label="<%= lang === 'ar' ? 'دردشة خدمة العملاء' : 'Customer care chat' %>">
            <div class="whatsapp-panel-header">
                <div>
                    <strong><%= lang === 'ar' ? 'عجمان لكجري' : 'AJMAN LUXURY' %></strong>
                    <span><%= lang === 'ar' ? 'خدمة العملاء عبر واتساب' : 'WhatsApp customer care' %></span>
                </div>
                <button type="button" data-whatsapp-close aria-label="<%= lang === 'ar' ? 'إغلاق' : 'Close' %>">×</button>
            </div>
            <div class="whatsapp-panel-body" data-whatsapp-messages>
                <div class="chat-bubble support">
                    <%= lang === 'ar' ? 'مرحباً بك 👋 كيف يمكننا مساعدتك في اختيار العطر أو إتمام الطلب؟' : 'Hello 👋 How can we help you choose a perfume or complete your order?' %>
                </div>
            </div>
            <form class="whatsapp-form" data-whatsapp-form>
                <strong class="live-chat-title"><%= lang === 'ar' ? 'لايف شات داخلي' : 'Internal Live Chat' %></strong>
                <input name="name" placeholder="<%= lang === 'ar' ? 'اسمك' : 'Your name' %>">
                <input name="phone" placeholder="<%= lang === 'ar' ? 'رقم الهاتف' : 'Phone number' %>">
                <textarea name="message" rows="3" required placeholder="<%= lang === 'ar' ? 'اكتب استفسارك هنا...' : 'Write your question here...' %>"></textarea>
                <button type="submit"><%= lang === 'ar' ? 'إرسال' : 'Send' %></button>
                <small data-whatsapp-status></small>
            </form>
        </section>
        <div class="chat-launchers">
            <a class="whatsapp-chat whatsapp-external-chat" href="<%= whatsappUrl %>" target="_blank" rel="noopener" aria-label="<%= lang === 'ar' ? 'فتح واتساب خارجي' : 'Open external WhatsApp chat' %>">
                <span class="whatsapp-icon" aria-hidden="true">
                    <svg class="whatsapp-logo" viewBox="0 0 32 32">
                        <path d="M16.01 3.2c-7.03 0-12.75 5.62-12.75 12.54 0 2.21.59 4.37 1.71 6.27L3.15 28.8l6.99-1.78a12.91 12.91 0 0 0 5.87 1.43c7.03 0 12.75-5.62 12.75-12.54S23.04 3.2 16.01 3.2Zm0 23.1c-1.84 0-3.65-.47-5.24-1.36l-.38-.21-4.15 1.06 1.1-4.01-.25-.41a10.33 10.33 0 0 1-1.61-5.63c0-5.73 4.72-10.4 10.53-10.4s10.53 4.67 10.53 10.4-4.72 10.56-10.53 10.56Zm5.78-7.77c-.32-.16-1.88-.92-2.17-1.02-.29-.11-.5-.16-.71.16-.21.31-.82 1.02-1 1.23-.18.21-.37.24-.69.08-.32-.16-1.34-.49-2.55-1.56-.94-.83-1.58-1.86-1.77-2.17-.18-.31-.02-.48.14-.64.14-.14.32-.37.47-.55.16-.18.21-.31.32-.52.11-.21.05-.39-.03-.55-.08-.16-.71-1.69-.97-2.31-.26-.61-.52-.52-.71-.53h-.6c-.21 0-.55.08-.84.39-.29.31-1.1 1.07-1.1 2.6s1.13 3.02 1.29 3.23c.16.21 2.22 3.35 5.38 4.69.75.32 1.34.51 1.8.65.76.24 1.45.21 1.99.13.61-.09 1.88-.76 2.15-1.49.26-.73.26-1.36.18-1.49-.08-.13-.29-.21-.61-.37Z"/>
                    </svg>
                </span>
                <span class="whatsapp-copy">
                    <strong><%= lang === 'ar' ? 'واتساب' : 'WhatsApp' %></strong>
                    <small><%= lang === 'ar' ? 'دردشة خارجية' : 'External chat' %></small>
                </span>
            </a>
            <button class="whatsapp-chat live-chat-launcher" type="button" data-whatsapp-toggle aria-label="<%= lang === 'ar' ? 'فتح لايف شات داخلي' : 'Open internal live chat' %>">
                <span class="whatsapp-icon">💬</span>
                <span class="whatsapp-copy">
                    <strong><%= lang === 'ar' ? 'لايف شات' : 'Live Chat' %></strong>
                    <small><%= lang === 'ar' ? 'داخل الموقع' : 'Inside site' %></small>
                </span>
            </button>
        </div>
    </div>

    <script src="/js/main.js"></script>
</body>
</html>
