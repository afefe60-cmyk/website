<%- include('layout', {
    body: `
<section class="page-hero compact">
    <div class="container">
        <p class="eyebrow">${t.products}</p>
        <h1>${t.ourProducts}</h1>
        <p>${t.collectionIntro}</p>
    </div>
</section>

<section class="products">
    <div class="container">
        <div class="products-grid">
            ${products.map((product) => `
                <article class="product-card ${product.tone}">
                    <a href="/product/${product.id}?lang=${lang}" class="product-visual" aria-label="${product.name}">
                        ${product.image ? `<img src="${product.image}" alt="${product.name}" class="product-photo">` : `<span class="bottle"></span>`}
                    </a>
                    <div class="product-info">
                        <h3>${product.name}</h3>
                        <p class="product-type">${product.type}</p>
                        <p class="product-size">${product.size}</p>
                        <p class="product-price">${product.price}</p>
                        <p class="product-description">${product.description}</p>
                        <a href="/product/${product.id}?lang=${lang}" class="view-details">${t.viewDetails}</a>
                    </div>
                </article>
            `).join('')}
        </div>
    </div>
</section>
    `,
    lang: lang,
    isRTL: isRTL,
    currentPath: currentPath,
    t: t
}) %>
